# Apply the build:<os> groups below automatically, keyed on the host OS, so the
# right C++ flags reach clang/gcc (Linux, macOS) versus MSVC (Windows) without
# every invocation having to pass --config.
common --enable_platform_specific_config

# C++17 for every C++ compile, spelled for the active compiler: clang/gcc take
# -std=c++17, MSVC takes /std:c++17.
build:linux --cxxopt=-std=c++17 --host_cxxopt=-std=c++17
build:macos --cxxopt=-std=c++17 --host_cxxopt=-std=c++17
build:windows --cxxopt=/std:c++17 --host_cxxopt=/std:c++17

# The LLVM toolchain adds -stdlib=libc++ to every C++ compile; clang treats it as
# a link-phase flag and warns it is "unused during compilation" on each .cc file
# (noisy across the third-party gtest/protobuf builds). Suppress that one benign
# warning for both the target and exec (`[for tool]`) configurations. MSVC does
# not use libc++, so Windows omits it.
build:linux --cxxopt=-Wno-unused-command-line-argument --host_cxxopt=-Wno-unused-command-line-argument
build:macos --cxxopt=-Wno-unused-command-line-argument --host_cxxopt=-Wno-unused-command-line-argument

build --java_runtime_version=remotejdk_11

# Windows: rules_dotnet (and the symlink-based staging rules) need real symlinks
# and runfiles trees. The startup flag is a no-op off Windows; the windows config
# group is auto-selected on Windows hosts (and CI also passes --config=windows).
startup --windows_enable_symlinks
common:windows --enable_runfiles

# The MSVC toolchain links fastbuild binaries with /DEBUG:FASTLINK, which recent
# MSVC toolchains dropped (warning LNK4315, falling back to /DEBUG:FULL). Ask for
# /DEBUG:FULL explicitly so the linker does not warn.
build:windows --linkopt=/DEBUG:FULL

# Build the C/C++ clients against a system LLVM instead of downloading the ~2 GB
# hermetic LLVM release. Selects system clang-tidy/clang-format/libc++ (via the
# flag) and the system C++ compiler toolchain (via --extra_toolchains, which
# outranks the registered hermetic toolchain). Requires an LLVM install at the
# path in MODULE.bazel's llvm.toolchain_root (present in the buildenv image).
# CI activates this in the container bazelrc; dev can pass it to reproduce CI.
common:system-llvm --//tools/build/llvm:toolchain=system
common:system-llvm --extra_toolchains=@llvm_system//:all
