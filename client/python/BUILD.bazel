test_suite(
    name = "test",
    tests = [
        ":client",
        ":client_base",
        ":lint",
    ],
)

client_test(
    name = "client",
    size = "medium",
    server_executable = "//tools/TestServer",
    tags = ["requires-network"],
    test_executable = ":clienttest",
)

client_test(
    name = "client_base",
    size = "medium",
    server_executable = "//tools/TestServer",
    tags = ["requires-network"],
    test_executable = ":clienttest_base",
)

deps = ["@pypi//protobuf"]

py_test(
    name = "clienttest",
    size = "small",
    src = ":python",
    pkg = "krpc-" + python_version,
    tags = ["requires-network"],
    deps = deps,
)

py_test(
    name = "clienttest_base",
    size = "small",
    src = ":python_base",
    pkg = "krpc-" + python_version,
    tags = ["requires-network"],
    deps = deps,
)

py_lint_test(
    name = "lint",
    size = "medium",
    black_exclude = ".*(schema|services)/.+",
    pkg = ":python",
    pkg_name = "krpc",
    pylint_config = "pylint.rc",
    deps = deps,
)
