load("@rules_python//python:defs.bzl", "py_library")
load("//:config.bzl", "python_version", "version")
load("//tools/build:client_test.bzl", "client_test")
load("//tools/build:python.bzl", "py_lint_test", "py_sdist", "py_test")
load("//tools/krpctools:clientgen.bzl", "clientgen_python")

exports_files(["CHANGES.txt"])

# The krpc package as an importable python library, for use by other python
# targets in this workspace (the sdists below are what is released)
py_library(
    name = "krpc_lib",
    srcs = [
        ":services-dockingcamera",
        ":services-drawing",
        ":services-infernalrobotics",
        ":services-kerbalalarmclock",
        ":services-krpc",
        ":services-lidar",
        ":services-remotetech",
        ":services-spacecenter",
        ":services-testservice",
        ":services-ui",
    ],
    visibility = ["//visibility:public"],
    deps = [":krpc_base_lib"],
)

# The krpc package without the generated service modules; clientgen (which
# generates those modules) depends on this, so this must not depend on
# clientgen's output
py_library(
    name = "krpc_base_lib",
    srcs = glob(["krpc/**/*.py"]) + [
        ":krpc-version-py",
        ":schema-py",
    ],
    imports = ["."],
    visibility = ["//visibility:public"],
    deps = ["@pypi//protobuf"],
)

genrule(
    name = "schema-py",
    srcs = ["//protobuf:python"],
    outs = ["krpc/schema/KRPC_pb2.py"],
    cmd = "for f in $(locations //protobuf:python); do case $$f in *KRPC_pb2.py) cp $$f $@;; esac; done",
)

genrule(
    name = "krpc-version-py",
    srcs = ["//:python_version"],
    outs = ["krpc/version.py"],
    cmd = 'cp "$<" "$@"',
)

# Needed as clientgen depends on these files
genrule(
    name = "python_base",
    srcs = [":python-without-services"],
    outs = ["krpc-python-base-%s.tar.gz" % version],
    cmd = 'cp "$<" "$@"',
    output_to_bindir = True,
    visibility = ["//visibility:public"],
)

py_sdist(
    name = "python-without-services",
    out = "krpc-base-%s.tar.gz" % version,
    files = [
        "CHANGES.txt",
        "LICENSE",
        "pyproject.toml",
        "//:COPYING",
        "//:COPYING.LESSER",
        "//:python_version",
        "//:readme",
        "//:version",
        "//protobuf:python",
    ] + glob(["krpc/**/*"]),
    path_map = {
        "version.py": "krpc/version.py",
        "client/python/": "",
        "protobuf/": "krpc/schema/",
    },
)

genrule(
    name = "python",
    srcs = [":python-pypi"],
    outs = ["krpc-python-%s.tar.gz" % version],
    cmd = 'cp "$<" "$@"',
    output_to_bindir = True,
    visibility = ["//visibility:public"],
)

py_sdist(
    name = "python-pypi",
    out = "krpc-%s.tar.gz" % version,
    files = [
        "CHANGES.txt",
        "LICENSE",
        "pyproject.toml",
        ":services-dockingcamera",
        ":services-drawing",
        ":services-infernalrobotics",
        ":services-kerbalalarmclock",
        ":services-krpc",
        ":services-lidar",
        ":services-remotetech",
        ":services-spacecenter",
        ":services-testservice",
        ":services-ui",
        "//:COPYING",
        "//:COPYING.LESSER",
        "//:python_version",
        "//:readme",
        "//:version",
        "//protobuf:python",
    ] + glob(["krpc/**/*"]),
    path_map = {
        "version.py": "krpc/version.py",
        "client/python/": "",
        "protobuf/": "krpc/schema/",
    },
)

clientgen_python(
    name = "services-krpc",
    out = "krpc/services/krpc.py",
    defs = "//core:ServiceDefinitions",
    service = "KRPC",
)

clientgen_python(
