module(name = "krpc")

http_archive = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

http_file = use_repo_rule("@bazel_tools//tools/build_defs/repo:http.bzl", "http_file")

bazel_dep(name = "platforms", version = "1.1.0")
bazel_dep(name = "bazel_skylib", version = "1.9.0")
bazel_dep(name = "rules_cc", version = "0.2.19")
bazel_dep(name = "rules_pkg", version = "1.2.0")
bazel_dep(name = "rules_python", version = "2.0.3")
bazel_dep(name = "rules_java", version = "9.6.1")
bazel_dep(name = "protobuf", version = "35.1")
bazel_dep(name = "rules_dotnet", version = "0.22.1")

dotnet = use_extension("@rules_dotnet//dotnet:extensions.bzl", "dotnet")
dotnet.toolchain(dotnet_version = "8.0.422")
use_repo(dotnet, "dotnet_toolchains")

register_toolchains("@dotnet_toolchains//:all")

# LLVM toolchain for the C/C++ clients (compiler + clang-format/clang-tidy). Two
# variants: a hermetic download (the default, used on dev) and a system install
# (used in CI via `--config=system-llvm`, which avoids the ~2 GB download). Switch
# with `--//tools/build/llvm:toolchain=system` (see .bazelrc + tools/build/llvm).
bazel_dep(name = "toolchains_llvm", version = "1.8.0")

llvm = use_extension("@toolchains_llvm//toolchain/extensions:llvm.bzl", "llvm")

# Hermetic (downloads the LLVM release) -- registered as the default toolchain.
llvm.toolchain(
    name = "llvm_toolchain",
    llvm_version = "20.1.3",
)

# System (no download; toolchains_llvm resolves clang from an existing install).
# The path is the apt.llvm.org clang-20 layout baked into the buildenv image; it
# only exists inside the container, and is only used when `--config=system-llvm`
# opts in via --extra_toolchains, so dev checkouts are unaffected.
llvm.toolchain(
    name = "llvm_system",
    llvm_version = "20.1.3",
)
llvm.toolchain_root(
    name = "llvm_system",
    path = "/usr/lib/llvm-20",
)

# Path-mode generates only the config repo (@llvm_system); there is no downloaded
# @llvm_system_llvm binaries repo, so the clang-tidy/clang-format labels for system
# mode come from wrapper scripts in //tools/build/llvm, not from here.
use_repo(llvm, "llvm_system", "llvm_toolchain", "llvm_toolchain_llvm")

register_toolchains("@llvm_toolchain//:all")

bazel_dep(name = "rules_jvm_external", version = "7.0")

maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
maven.install(
    artifacts = [
        "com.google.protobuf:protobuf-java:4.35.1",
        "com.puppycrawl.tools:checkstyle:10.26.1",
        "junit:junit:4.13.2",
        "org.hamcrest:hamcrest:3.0",
        "org.javatuples:javatuples:1.2",
    ],
    known_contributing_modules = ["protobuf"],
    lock_file = "//:maven_install.json",
    repositories = ["https://repo1.maven.org/maven2"],
)
use_repo(maven, "maven", "unpinned_maven")

python = use_extension("@rules_python//python/extensions:python.bzl", "python")
python.toolchain(
    is_default = True,
    python_version = "3.12",
)

pip = use_extension("@rules_python//python/extensions:pip.bzl", "pip")
pip.parse(
    hub_name = "pypi",
    python_version = "3.12",
    requirements_lock = "//tools/build/python:requirements_lock.txt",
)
use_repo(pip, "pypi")

